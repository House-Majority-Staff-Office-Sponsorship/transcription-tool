#environment variables
YOUTUBE_API_KEY=Your API key here
CHANNEL_ID=UCvoLAX1ww3e63K8qQ5of0bw
DATABASE_URL=sqlite:///data/db/transcription.db
POLL_INTERVAL_SECONDS=600
MAX_VIDEOS=2
CHUNK_SECONDS=600
OVERLAP_SECONDS=5
MODEL_SIZE=small
DEVICE=cuda
COMPUTE_TYPE=int8

#google drive uploading to be removed later
GOOGLE_DRIVE_UPLOAD_ENABLED=false
GOOGLE_DRIVE_AUTH_MODE=
GOOGLE_DRIVE_OAUTH_CLIENT_JSON=
GOOGLE_DRIVE_OAUTH_TOKEN_JSON=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=


#transcription backend is either whisperx or faster-whisper
TRANSCRIPTION_BACKEND=faster-whisper
WHISPERX_MODEL_SIZE=small
WHISPERX_COMPUTE_TYPE=float16
WHISPERX_BATCH_SIZE=16
WHISPERX_LANGUAGE=en
WHISPERX_ALIGN=true
WHISPERX_DIARIZE=false
#Token only required for diarization
WHISPERX_HF_TOKEN=